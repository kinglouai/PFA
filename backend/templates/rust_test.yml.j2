---
name: Rust Tests

on:
{% if branch_trigger == "push" %}
  push:
    branches: [main, develop]
{% elif branch_trigger == "pull_request" %}
  pull_request:
    branches: [main]
{% else %}
  push:
    branches: [main, develop]
  pull_request:
    branches: [main]
{% endif %}

jobs:
  test:
    runs-on: ubuntu-latest
    timeout-minutes: 20
    steps:
      - name: Checkout code
        uses: actions/checkout@v4

      - name: Install Rust toolchain
        uses: dtolnay/rust-toolchain@stable

      - name: Cache cargo registry
        uses: actions/cache@v3
        with:
{% raw %}
          path: |
            ~/.cargo/registry
            ~/.cargo/git
            target
          key: ${{ runner.os }}-cargo-${{ hashFiles('**/Cargo.lock') }}
          restore-keys: |
            ${{ runner.os }}-cargo-
{% endraw %}

      - name: Run tests
        run: {{ test_command }}
{% if enable_deploy_sim %}

  deploy:
    needs: [test]
    runs-on: ubuntu-latest
    timeout-minutes: 10
    steps:
      - name: Simulate deployment
        run: echo "Deploying application..."
{% endif %}
