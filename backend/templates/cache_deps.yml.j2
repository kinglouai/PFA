# Dependency caching partial — included by other templates
{% if enable_cache %}
{% raw %}
    - name: Cache dependencies
      uses: actions/cache@v3
      with:
{% endraw %}
{% if cache_key == "pip" %}
{% raw %}
        path: ~/.cache/pip
        key: ${{ runner.os }}-pip-${{ hashFiles('**/requirements.txt') }}
        restore-keys: |
          ${{ runner.os }}-pip-
{% endraw %}
{% elif cache_key == "npm" %}
{% raw %}
        path: ~/.npm
        key: ${{ runner.os }}-npm-${{ hashFiles('**/package-lock.json') }}
        restore-keys: |
          ${{ runner.os }}-npm-
{% endraw %}
{% elif cache_key == "yarn" %}
{% raw %}
        path: .yarn/cache
        key: ${{ runner.os }}-yarn-${{ hashFiles('**/yarn.lock') }}
        restore-keys: |
          ${{ runner.os }}-yarn-
{% endraw %}
{% elif cache_key == "pnpm" %}
{% raw %}
        path: ~/.pnpm-store
        key: ${{ runner.os }}-pnpm-${{ hashFiles('**/pnpm-lock.yaml') }}
        restore-keys: |
          ${{ runner.os }}-pnpm-
{% endraw %}
{% elif cache_key == "maven" %}
{% raw %}
        path: ~/.m2/repository
        key: ${{ runner.os }}-maven-${{ hashFiles('**/pom.xml') }}
        restore-keys: |
          ${{ runner.os }}-maven-
{% endraw %}
{% elif cache_key == "gradle" %}
{% raw %}
        path: ~/.gradle/caches
        key: ${{ runner.os }}-gradle-${{ hashFiles('**/*.gradle*') }}
        restore-keys: |
          ${{ runner.os }}-gradle-
{% endraw %}
{% endif %}
{% endif %}
