---
name: PHP Tests

on:
{% if branch_trigger == "push" %}
  push:
    branches: [main, master, develop]
{% elif branch_trigger == "pull_request" %}
  pull_request:
    branches: [main, master]
{% else %}
  push:
    branches: [main, master, develop]
  pull_request:
    branches: [main, master]
{% endif %}

jobs:
  test:
    runs-on: ubuntu-latest
    timeout-minutes: 15
    steps:
      - name: Checkout code
        uses: actions/checkout@v4

      - name: Set up PHP {{ version }}
        uses: shivammathur/setup-php@v2
        with:
          php-version: '{{ version }}'
          extensions: mbstring, xml, ctype, json
          coverage: pcov

      - name: Install dependencies
        run: |
          composer config policy.advisories.block false || true
          composer install --no-interaction --prefer-dist
{% set frameworks = framework if framework is iterable and framework is not string else [framework] %}
{% if frameworks and "laravel" in (frameworks | join(" ") | lower) %}

      - name: Prepare Laravel Application
        run: |
          cp .env.example .env 2>/dev/null || echo "APP_KEY=" > .env
          if [ -f artisan ]; then php artisan key:generate --force; fi
{% endif %}

      - name: Run tests
        run: {{ test_command }}
{% if enable_deploy_sim %}

  deploy:
    needs: [test]
    runs-on: ubuntu-latest
    timeout-minutes: 10
    steps:
      - name: Simulate deployment
        run: echo "Deploying application..."
{% endif %}
