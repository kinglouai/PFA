---
name: PHP Tests

on:
{% if branch_trigger == "push" %}
  push:
    branches: [main, develop]
{% elif branch_trigger == "pull_request" %}
  pull_request:
    branches: [main]
{% else %}
  push:
    branches: [main, develop]
  pull_request:
    branches: [main]
{% endif %}

jobs:
  test:
    runs-on: ubuntu-latest
    timeout-minutes: 15
    steps:
      - name: Checkout code
        uses: actions/checkout@v4

      - name: Set up PHP {{ version }}
        uses: shivammathur/setup-php@v2
        with:
          php-version: '{{ version }}'
          extensions: mbstring, xml, ctype, json
          coverage: none

      - name: Install dependencies
        run: composer install --no-interaction --prefer-dist

      - name: Run tests
        run: {{ test_command }}
{% if enable_deploy_sim %}

  deploy:
    needs: [test]
    runs-on: ubuntu-latest
    timeout-minutes: 10
    steps:
      - name: Simulate deployment
        run: echo "Deploying application..."
{% endif %}
