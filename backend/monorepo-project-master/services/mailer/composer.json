{
    "name": "monorepo/mailer-service",
    "description": "Laravel-based email/notification service",
    "type": "project",
    "require": {
        "php": "^8.2",
        "laravel/framework": "^11.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0",
        "laravel/pint": "^1.0",
        "mockery/mockery": "^1.6"
    },
    "autoload": {
        "psr-4": { "App\\": "app/" }
    },
    "autoload-dev": {
        "psr-4": { "Tests\\": "tests/" }
    },
    "scripts": {
        "test": "vendor/bin/phpunit --coverage-text",
        "lint": "vendor/bin/pint --test",
        "format": "vendor/bin/pint"
    }
}
